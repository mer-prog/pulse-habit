{
  "expo": {
    "name": "PulseHabit",
    "slug": "pulse-habit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pulsehabit",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFDF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pulsehabit.app",
      "infoPlist": {
        "NSCameraUsageDescription": "習慣の達成記録に写真を撮影するために使用します",
        "NSPhotoLibraryUsageDescription": "習慣の達成記録に写真を添付するために使用します"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF5722"
      },
      "package": "com.pulsehabit.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF5722"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "習慣の達成記録に写真を添付するために使用します",
          "cameraPermission": "習慣の達成記録に写真を撮影するために使用します"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "owner": "mer-prog",
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/"
    }
  }
}
